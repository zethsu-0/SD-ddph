<Window x:Class="ddph.CustomItemsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Custom Order"
        Height="760"
        Width="1180"
        MinHeight="700"
        MinWidth="1020"
        Background="{StaticResource ThemeBaseBrush}"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None">
    <Window.Resources>
        <Style x:Key="SubmitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ThemeAccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ThemeInkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ThemeAccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource ThemeAccentSoftBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource ThemeInkSoftBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Close Button Overlay -->
        <Button Width="100"
                Height="36"
                Margin="0,-18,-18,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="100"
                FontSize="18"
                FontWeight="SemiBold"
                Background="{StaticResource ThemeAccentSoftBrush}"
                Foreground="{StaticResource ThemeInkBrush}"
                BorderBrush="{StaticResource ThemeBorderBrush}"
                BorderThickness="1"
                ToolTip="Back"
                Click="CloseButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                        <TextBlock Text="&#x2190;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.82"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.65"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Border Background="{StaticResource ThemeBaseBrush}"
                BorderThickness="0"
                BorderBrush="Transparent"
                Margin="-18,-18,-18,0"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Custom Order"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ThemeInkBrush}"/>
                    <TextBlock Margin="0,8,0,0"
                               Text="Compact cashier intake for website-style custom orders"
                               Foreground="{StaticResource ThemeInkSoftBrush}"/>
                </StackPanel>


            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource ThemeSurfaceBrush}"
                BorderBrush="{StaticResource ThemeBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.ColumnSpan="3"
                        Background="{StaticResource ThemeAccentSoftBrush}"
                        BorderBrush="{StaticResource ThemeAccentBrush}"
                        BorderThickness="1,0,0,0"
                        Padding="12"
                        CornerRadius="10">
                    <TextBlock Foreground="{StaticResource ThemeInkBrush}"
                               TextWrapping="Wrap">
                        <Run Text="Tip: "/><Run Text="Keep the details concise and clear so the baker can confirm the custom design quickly."/>
                    </TextBlock>
                </Border>

                <StackPanel Grid.Row="2"
                            Grid.Column="0">
                    <TextBlock Margin="0,0,0,6"
                               Text="Full Name *"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                    <TextBox Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Margin="0,12,0,6"
                               Text="Phone Number *"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                    <TextBox Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Margin="0,12,0,6"
                               Text="Email"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                    <TextBox Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding CustomerEmail, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Margin="0,0,0,6"
                                       Text="Product Type *"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                            <ComboBox Height="36"
                                      ItemsSource="{Binding ProductTypes}"
                                      SelectedItem="{Binding ProductType, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Margin="0,0,0,6"
                                       Text="Quantity *"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                            <TextBox Height="36"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Margin="0,12,0,6"
                               Text="Size / Serving *"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                    <TextBox Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding Size, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Margin="0,12,0,6"
                               Text="Flavor Preferences"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                    <TextBox Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding Flavor, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Margin="0,0,0,6"
                                       Text="Pickup Date *"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                            <TextBox Height="36"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding PickupDate, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Margin="0,0,0,6"
                                       Text="Pickup Time *"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                            <TextBox Height="36"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding PickupTime, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="2">
                    <TextBlock Margin="0,0,0,6"
                               Text="Design Description *"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                    <TextBox MinHeight="100"
                             Padding="10"
                             Text="{Binding DesignDescription, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>

                    <TextBlock Margin="0,12,0,6"
                               Text="Delivery Address"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                    <TextBox MinHeight="64"
                             Padding="10"
                             Text="{Binding DeliveryAddress, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>

                    <TextBlock Margin="0,12,0,6"
                               Text="Additional Notes"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                    <TextBox MinHeight="74"
                             Padding="10"
                             Text="{Binding AdditionalNotes, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>
                </StackPanel>

                <Border Grid.Row="4"
                        Grid.ColumnSpan="3"
                        Background="{StaticResource ThemeAccentSoftBrush}"
                        BorderBrush="{StaticResource ThemeBorderBrush}"
                        BorderThickness="1,0,0,0"
                        Padding="12"
                        CornerRadius="10" Margin="0,33,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Margin="0,20,0,6"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource ThemeInkBrush}">
                            <Run Text="Note: "/><Run Text="This submits a custom order to Firebase as a pending inquiry with price still set to 0."/>
                        </TextBlock>

                        <Button Grid.Column="1"
                                Width="190"
                                Height="42"
                                Margin="18,0,0,0"
                                Content="Submit Custom Order"
                                Command="{Binding SubmitCustomOrderCommand}"
                                Style="{StaticResource SubmitButtonStyle}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
