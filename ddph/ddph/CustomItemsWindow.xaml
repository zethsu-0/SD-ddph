<Window x:Class="ddph.CustomItemsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Custom Order"
        Height="760"
        Width="1180"
        MinHeight="700"
        MinWidth="1020"
        Background="#FFF9E6"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None">
    <Window.Resources>
        <Style x:Key="SubmitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#5D4037"/>
            <Setter Property="Foreground" Value="#fff8e113"/>
            <Setter Property="BorderBrush" Value="#5D4037"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#fff8e113"/>
                    <Setter Property="BorderBrush" Value="#fff8e113"/>
                    <Setter Property="Foreground" Value="#F5F0EC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Close Button Overlay -->
        <Button Content="✕"
                Width="36"
                Height="36"
                Margin="0,-18,-18,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="100"
                FontSize="14"
                FontWeight="Bold"
                Background="#FDECEA"
                Foreground="#C0392B"
                BorderBrush="#F5C6C2"
                ToolTip="Close"
                Click="CloseButton_Click"/>

        <Border Background="#FFFDFB"
                BorderThickness="0"
                BorderBrush="Transparent"
                Margin="-18,-18,-18,0"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Custom Order"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#5D4037"/>
                    <TextBlock Margin="0,8,0,0"
                               Text="Compact cashier intake for website-style custom orders"
                               Foreground="#8D6E63"/>
                </StackPanel>


            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E7DDD1"
                BorderThickness="1"
                CornerRadius="14"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.ColumnSpan="3"
                        Background="#E3F2FD"
                        BorderBrush="#2196F3"
                        BorderThickness="1,0,0,0"
                        Padding="12"
                        CornerRadius="10">
                    <TextBlock Foreground="#5D4037"
                               TextWrapping="Wrap">
                        <Run Text="Tip: "/><Run Text="Keep the details concise and clear so the baker can confirm the custom design quickly."/>
                    </TextBlock>
                </Border>

                <StackPanel Grid.Row="2"
                            Grid.Column="0">
                    <TextBlock Margin="0,0,0,6"
                               Text="Full Name *"
                               FontWeight="SemiBold"
                               Foreground="#5D4037"/>
                    <TextBox Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Margin="0,12,0,6"
                               Text="Phone Number *"
                               FontWeight="SemiBold"
                               Foreground="#5D4037"/>
                    <TextBox Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Margin="0,12,0,6"
                               Text="Email"
                               FontWeight="SemiBold"
                               Foreground="#5D4037"/>
                    <TextBox Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding CustomerEmail, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Margin="0,0,0,6"
                                       Text="Product Type *"
                                       FontWeight="SemiBold"
                                       Foreground="#5D4037"/>
                            <ComboBox Height="36"
                                      ItemsSource="{Binding ProductTypes}"
                                      SelectedItem="{Binding ProductType, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Margin="0,0,0,6"
                                       Text="Quantity *"
                                       FontWeight="SemiBold"
                                       Foreground="#5D4037"/>
                            <TextBox Height="36"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Margin="0,12,0,6"
                               Text="Size / Serving *"
                               FontWeight="SemiBold"
                               Foreground="#5D4037"/>
                    <TextBox Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding Size, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Margin="0,12,0,6"
                               Text="Flavor Preferences"
                               FontWeight="SemiBold"
                               Foreground="#5D4037"/>
                    <TextBox Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding Flavor, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Margin="0,0,0,6"
                                       Text="Pickup Date *"
                                       FontWeight="SemiBold"
                                       Foreground="#5D4037"/>
                            <TextBox Height="36"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding PickupDate, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Margin="0,0,0,6"
                                       Text="Pickup Time *"
                                       FontWeight="SemiBold"
                                       Foreground="#5D4037"/>
                            <TextBox Height="36"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding PickupTime, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="2">
                    <TextBlock Margin="0,0,0,6"
                               Text="Design Description *"
                               FontWeight="SemiBold"
                               Foreground="#5D4037"/>
                    <TextBox MinHeight="100"
                             Padding="10"
                             Text="{Binding DesignDescription, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>

                    <TextBlock Margin="0,12,0,6"
                               Text="Delivery Address"
                               FontWeight="SemiBold"
                               Foreground="#5D4037"/>
                    <TextBox MinHeight="64"
                             Padding="10"
                             Text="{Binding DeliveryAddress, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>

                    <TextBlock Margin="0,12,0,6"
                               Text="Additional Notes"
                               FontWeight="SemiBold"
                               Foreground="#5D4037"/>
                    <TextBox MinHeight="74"
                             Padding="10"
                             Text="{Binding AdditionalNotes, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>
                </StackPanel>

                <Border Grid.Row="4"
                        Grid.ColumnSpan="3"
                        Background="#FFF3CD"
                        BorderBrush="#FFC107"
                        BorderThickness="1,0,0,0"
                        Padding="12"
                        CornerRadius="10" Margin="0,33,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Margin="0,20,0,6"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="#5D4037">
                            <Run Text="Note: "/><Run Text="This submits a custom order to Firebase as a pending inquiry with price still set to 0."/>
                        </TextBlock>

                        <Button Grid.Column="1"
                                Width="190"
                                Height="42"
                                Margin="18,0,0,0"
                                Content="Submit Custom Order"
                                Command="{Binding SubmitCustomOrderCommand}"
                                Style="{StaticResource SubmitButtonStyle}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
