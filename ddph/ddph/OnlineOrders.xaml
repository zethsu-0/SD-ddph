<Window x:Class="ddph.OnlineOrders"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Orders"
        Height="1356"
        Width="1320"
        MinHeight="640"
        MinWidth="1100"
        Background="{StaticResource ThemeBaseBrush}"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <SolidColorBrush x:Key="OrderBorderBrush" Color="#26D4C3BE"/>
        <Style x:Key="OrderHeaderButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource ThemeInkSoftBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="OrderPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ThemeSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource OrderBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
        </Style>
        <Style x:Key="OrderMetricStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ThemeCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource OrderBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24"
          MinWidth="1040">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Width="100"
                Height="40"
                Margin="0,-24,-24,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="100"
                FontSize="18"
                FontWeight="SemiBold"
                Background="{StaticResource ThemeCardBrush}"
                Foreground="{StaticResource ThemeAccentBrush}"
                BorderBrush="Transparent"
                BorderThickness="0"
                ToolTip="Back"
                Click="CloseButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="18">
                        <TextBlock Text="&#x2190;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.82"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.65"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Margin="0,6,0,0"
                           Text="Review website orders and register tickets from one history board."
                           Foreground="{StaticResource ThemeInkSoftBrush}"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Height="44"
                    VerticalAlignment="Center"
                    Background="{StaticResource ThemeSurfaceBrush}"
                    BorderBrush="{StaticResource OrderBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22">
                <TextBox VerticalContentAlignment="Center"
                         Padding="14,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            </Border>

            <Button Grid.Column="3"
                    Height="44"
                    VerticalAlignment="Center"
                    Content="Refresh"
                    Command="{Binding RefreshCommand}"
                    Background="{StaticResource ThemeToastBrush}"
                    Foreground="White"/>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource ThemeSurfaceBrush}"
                BorderBrush="{StaticResource OrderBorderBrush}"
                BorderThickness="1"
                CornerRadius="22"
                Padding="8">
            <StackPanel Orientation="Horizontal">
                <Button Content="Online Orders"
                        Height="44"
                        Width="150"
                        Padding="20,10"
                        Margin="0,0,8,0"
                        Command="{Binding ShowOnlineOrdersCommand}"
                        BorderBrush="Transparent"
                        BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource ThemeInkSoftBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="16">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ThemeCardBrush}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsOnlineTabSelected}" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ThemeCardBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource ThemeAccentBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Custom Orders"
                        Padding="20,10"
                        Height="44"
                        Width="150"
                        Margin="0,0,8,0"
                        Command="{Binding ShowCustomOrdersCommand}"
                        BorderBrush="Transparent"
                        BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource ThemeInkSoftBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="16">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ThemeCardBrush}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsCustomTabSelected}" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ThemeCardBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource ThemeAccentBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Register Orders"
                        Padding="20,10"
                        Height="44"
                        Width="150"
                        Margin="0,0,8,0"
                        Command="{Binding ShowRegisterOrdersCommand}"
                        BorderBrush="Transparent"
                        BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource ThemeInkSoftBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="16">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ThemeCardBrush}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsRegisterTabSelected}" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ThemeCardBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource ThemeAccentBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Kiosk Sales"
                        Padding="20,10"
                        Height="44"
                        Width="150"
                        Command="{Binding ShowKioskSalesCommand}"
                        BorderBrush="Transparent"
                        BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource ThemeInkSoftBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="16">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ThemeCardBrush}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsKioskTabSelected}" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ThemeCardBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource ThemeAccentBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource OrderPanelStyle}"
                            Padding="24">
                        <StackPanel>
                            <TextBlock Text="{Binding ActiveTabLabel}"
                                       FontSize="22"
                                       FontFamily="{StaticResource ThemeHeadlineFont}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ThemeInkBrush}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding ActiveOrderCount, StringFormat={}{0} results}"
                                       Foreground="{StaticResource ThemeInkSoftBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource OrderMetricStyle}"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="{Binding PrimaryMetricLabel}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ThemeInkSoftBrush}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding ActiveOrderCount}"
                                       FontSize="28"
                                       FontFamily="{StaticResource ThemeHeadlineFont}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ThemeInkBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Style="{StaticResource OrderMetricStyle}"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Revenue"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ThemeInkSoftBrush}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding ActiveRevenue, StringFormat={}{0:C}}"
                                       FontSize="24"
                                       FontFamily="{StaticResource ThemeHeadlineFont}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ThemeInkBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6"
                            Style="{StaticResource OrderMetricStyle}"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="{Binding SecondaryMetricLabel}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ThemeInkSoftBrush}"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding SecondaryMetricValue}"
                                       FontSize="28"
                                       FontFamily="{StaticResource ThemeHeadlineFont}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ThemeInkBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Style="{StaticResource OrderPanelStyle}"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="118"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="112"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="Order Number"
                                    Command="{Binding SortOrdersCommand}"
                                    CommandParameter="OrderNumber"
                                    Style="{StaticResource OrderHeaderButtonStyle}" HorizontalContentAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Customer"
                                    Command="{Binding SortOrdersCommand}"
                                    CommandParameter="DisplayName"
                                    Style="{StaticResource OrderHeaderButtonStyle}" HorizontalContentAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Status"
                                    Command="{Binding SortOrdersCommand}"
                                    CommandParameter="Status"
                                    Style="{StaticResource OrderHeaderButtonStyle}" HorizontalContentAlignment="Center" Grid.ColumnSpan="2" Margin="240,0,34,1"/>
                            <Button Grid.Column="3"
                                    Content="Date"
                                    Command="{Binding SortOrdersCommand}"
                                    CommandParameter="Date"
                                    Style="{StaticResource OrderHeaderButtonStyle}" HorizontalContentAlignment="Center"/>
                            <Button Grid.Column="4"
                                    Content="Total"
                                    Command="{Binding SortOrdersCommand}"
                                    CommandParameter="Total"
                                    HorizontalContentAlignment="Right"
                                    Style="{StaticResource OrderHeaderButtonStyle}"/>
                        </Grid>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding ActiveOrdersView}"
                                 SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.Resources>
                                <Style TargetType="ScrollBar">
                                    <Setter Property="Width" Value="3"/>
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,10"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16"
                                            Background="{StaticResource ThemeCardBrush}"
                                            BorderBrush="{StaticResource OrderBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="118"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="112"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock VerticalAlignment="Center"
                                                       Text="{Binding OrderNumber}"
                                                       FontWeight="Bold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource ThemeAccentBrush}"/>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource ThemeInkBrush}"/>
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding CustomerPhone}"
                                                           Foreground="{StaticResource ThemeInkSoftBrush}"/>
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Padding="10,5"
                                                    HorizontalAlignment="Left"
                                                    Background="{Binding StatusBackground}"
                                                    CornerRadius="14">
                                                <TextBlock Text="{Binding Status}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding StatusForeground}"/>
                                            </Border>

                                            <TextBlock Grid.Column="3"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Date}"
                                                       Foreground="{StaticResource ThemeInkSoftBrush}"/>

                                            <TextBlock Grid.Column="4"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Text="{Binding Total, StringFormat={}{0:C}}"
                                                       FontFamily="{StaticResource ThemeHeadlineFont}"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource ThemeInkBrush}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource OrderPanelStyle}"
                            Padding="24">
                        <StackPanel>
                            <TextBlock Text="Order Details"
                                       FontSize="24"
                                       FontFamily="{StaticResource ThemeHeadlineFont}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ThemeAccentBrush}"/>

                            <Border Margin="0,18,0,0"
                                    Padding="18"
                                    Background="{StaticResource ThemeCardBrush}"
                                    BorderBrush="{StaticResource OrderBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="22">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedOrder.DisplayName, TargetNullValue=No order selected}"
                                               FontSize="20"
                                               FontFamily="{StaticResource ThemeHeadlineFont}"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ThemeInkBrush}"/>
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding SelectedOrder.SourceLabel, StringFormat={}Source: {0}}"
                                               Foreground="{StaticResource ThemeInkSoftBrush}"/>
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding SelectedOrder.Date, StringFormat={}Placed: {0}}"
                                               Foreground="{StaticResource ThemeInkSoftBrush}"/>
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding SelectedOrder.CustomerPhone, StringFormat={}Phone: {0}}"
                                               Foreground="{StaticResource ThemeInkSoftBrush}"/>
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding SelectedOrder.CustomerEmail, StringFormat={}Info: {0}}"
                                               Foreground="{StaticResource ThemeInkSoftBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="18"
                                    Background="{StaticResource ThemeCardBrush}"
                                    BorderBrush="{StaticResource OrderBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="22">
                                <StackPanel>
                                    <TextBlock Text="Order Summary"
                                               FontSize="18"
                                               FontFamily="{StaticResource ThemeHeadlineFont}"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ThemeInkBrush}"/>
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding SelectedOrderItemCount, StringFormat={}{0} items in this ticket}"
                                               Foreground="{StaticResource ThemeInkSoftBrush}"/>

                                    <ItemsControl Margin="0,14,0,0"
                                                  ItemsSource="{Binding SelectedOrder.Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource ThemeInkBrush}"/>
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Text="{Binding Quantity, StringFormat={}Qty {0}}"
                                                                   Foreground="{StaticResource ThemeInkSoftBrush}"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding Subtotal, StringFormat={}{0:C}}"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource ThemeAccentBrush}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Margin="0,10,0,0"
                                               HorizontalAlignment="Right"
                                               Text="{Binding SelectedOrder.Total, StringFormat={}Total: {0:C}}"
                                               FontSize="22"
                                               FontFamily="{StaticResource ThemeHeadlineFont}"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ThemeInkBrush}"/>
                                    <StackPanel Margin="0,16,0,0"
                                                Visibility="{Binding IsRegisterTabSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding SelectedOrder.Payment, StringFormat={}Payment: {0:C}}"
                                                   Foreground="{StaticResource ThemeInkSoftBrush}"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding SelectedOrder.Change, StringFormat={}Change: {0:C}}"
                                                   Foreground="{StaticResource ThemeInkSoftBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="18"
                                    Background="{StaticResource ThemeCardBrush}"
                                    BorderBrush="{StaticResource OrderBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="22">
                                <StackPanel>
                                    <TextBlock Text="Status"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ThemeInkBrush}"/>
                                    <Border Margin="0,12,0,0"
                                            Padding="12"
                                            Background="{Binding SelectedOrder.StatusBackground}"
                                            CornerRadius="16">
                                        <TextBlock Text="{Binding SelectedOrder.Status}"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding SelectedOrder.StatusForeground}"/>
                                    </Border>

                                    <StackPanel Margin="0,16,0,0"
                                                Visibility="{Binding CanEditOnlineOrder, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Change Status"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource ThemeInkBrush}"/>
                                        <UniformGrid Margin="0,14,0,0"
                                                     Columns="2"
                                                     Rows="3">
                                            <Button Margin="0,0,10,10"
                                                    Height="42"
                                                    Command="{Binding PendingOrderCommand}"
                                                    Background="{StaticResource ThemeAccentSoftBrush}"
                                                    Foreground="{StaticResource ThemeAccentBrush}"
                                                    Content="Pending"/>
                                            <Button Margin="0,0,0,10"
                                                    Height="42"
                                                    Command="{Binding ConfirmOrderCommand}"
                                                    Background="{StaticResource ThemeGreenSoftBrush}"
                                                    Foreground="{StaticResource ThemeGreenBrush}"
                                                    Content="Confirm"/>
                                            <Button Margin="0,0,10,10"
                                                    Height="42"
                                                    Command="{Binding NeedsAdjustmentCommand}"
                                                    Background="{StaticResource ThemeAccentSoftBrush}"
                                                    Foreground="{StaticResource ThemeAccentBrush}"
                                                    Content="Adjust"/>
                                            <Button Margin="0,0,0,10"
                                                    Height="42"
                                                    Command="{Binding PreparingOrderCommand}"
                                                    Background="{StaticResource ThemeSurfaceSoftBrush}"
                                                    Foreground="{StaticResource ThemeAccentBrush}"
                                                    Content="Preparing"/>
                                            <Button Margin="0,0,10,0"
                                                    Height="42"
                                                    Command="{Binding MarkCompleteCommand}"
                                                    Background="{StaticResource ThemeSurfaceSoftBrush}"
                                                    Foreground="{StaticResource ThemeAccentBrush}"
                                                    Content="Complete"/>
                                            <Button Height="42"
                                                    Command="{Binding CancelOrderCommand}"
                                                    Background="{StaticResource ThemeRoseSoftBrush}"
                                                    Foreground="{StaticResource ThemeRoseBrush}"
                                                    Content="Cancel"/>
                                        </UniformGrid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="18"
                                    Background="{StaticResource ThemeCardBrush}"
                                    BorderBrush="{StaticResource OrderBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="22">
                                <StackPanel>
                                    <TextBlock Text="Daily Overview"
                                               FontSize="18"
                                               FontFamily="{StaticResource ThemeHeadlineFont}"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource ThemeAccentBrush}"/>
                                    <TextBlock Margin="0,12,0,0"
                                               Text="{Binding ActiveRevenue, StringFormat={}Revenue: {0:C}}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource ThemeInkBrush}"/>
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding ActiveAverageTicket, StringFormat={}Average Ticket: {0:C}}"
                                               Foreground="{StaticResource ThemeInkSoftBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
