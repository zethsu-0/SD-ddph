<Window x:Class="ddph.Views.ReceiptPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receipt Preview"
        Height="720"
        Width="720"
        MinHeight="520"
        MinWidth="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FFF8EF">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Receipt Preview"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#765449"/>
                <TextBlock x:Name="ReceiptPathTextBlock"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="#80504441"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Width="92"
                    Height="36"
                    VerticalAlignment="Top"
                    Content="Close"
                    Click="CloseButton_Click"/>
        </Grid>

        <Border Grid.Row="2"
                Background="#F5EDDE"
                CornerRadius="14"
                Padding="14">
            <ItemsControl x:Name="PreviewPagesItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8"
                                Background="White"
                                BorderBrush="#26D4C3BE"
                                BorderThickness="1">
                            <Image Source="{Binding}"
                                   Width="640"
                                   MaxHeight="560"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <TextBlock Grid.Row="4"
                   HorizontalAlignment="Right"
                   FontSize="12"
                   Foreground="#80504441"
                   Text="PDF generated locally."/>
    </Grid>
</Window>
