<Window x:Class="ddph.Views.ReceiptPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receipt Preview"
        Height="760"
        Width="620"
        MinHeight="620"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FFF8EF">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Receipt Preview"
                           FontSize="24"
                           FontStyle="Italic"
                           FontWeight="SemiBold"
                           Foreground="#765449"/>
                <TextBlock x:Name="ReceiptPathTextBlock"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="#80504441"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Width="44"
                    Height="44"
                    VerticalAlignment="Top"
                    Background="#EDE9E5"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Foreground="#765449"
                    FontWeight="SemiBold"
                    Content="x"
                    Click="CloseButton_Click"/>
        </Grid>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="4"
                Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="PreviewPagesItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="0"
                                Background="White"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                            <Image Source="{Binding}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="4" Margin="0,13,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Height="54"
                    Background="#EDECE8"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Foreground="#364F2F"
                    FontWeight="SemiBold"
                    Content="Cancel"
                    Click="CloseButton_Click"/>
            <Button Grid.Column="2"
                    Height="54"
                    Background="#9C5A42"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Content="Confirm"
                    Click="CloseButton_Click"/>
        </Grid>
    </Grid>
</Window>
