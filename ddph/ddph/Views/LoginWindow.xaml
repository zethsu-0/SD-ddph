<Window x:Class="ddph.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Icon="/dd.png"
        Background="#F6EBDC">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="0.8*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Image Source="/bg.jpg"
                   Stretch="UniformToFill"/>
            <Rectangle Fill="#26000000"/>
        </Grid>

        <Border Grid.Column="1"
                Background="#F6EBDC">
            <Grid>
                <Button Width="42"
                        Height="42"
                        Margin="0,26,30,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="#EFE3D3"
                        Foreground="#8B6256"
                        BorderBrush="Transparent"
                        Content="x"
                        Click="ExitButton_Click"/>

                <Border Width="380"
                        Padding="40,36"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#F4E9D9"
                        CornerRadius="26">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="DreamDoughPH"
                                       HorizontalAlignment="Center"
                                       FontSize="26"
                                       FontStyle="Italic"
                                       FontWeight="Bold"
                                       Foreground="#8B6256"/>
                            <TextBlock Margin="0,12,0,0"
                                       Text="Welcome Back"
                                       HorizontalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#5E4A43"/>
                            <TextBlock Margin="0,8,0,0"
                                       Text="Access your artisan portal"
                                       HorizontalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#9B8A80"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Username"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#6F5A52"/>
                            <Border Height="52"
                                    Margin="0,10,0,0"
                                    Background="#EFE7D8"
                                    CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="#B3A79C"
                                               Text="&#xE77B;"/>
                                    <TextBox x:Name="UsernameTextBox"
                                             Grid.Column="1"
                                             Padding="0"
                                             VerticalContentAlignment="Center"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#5E4A43"
                                             KeyDown="LoginInput_KeyDown"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="4">
                            <TextBlock Text="Pin/Password"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#6F5A52"/>
                            <Border Height="52"
                                    Margin="0,10,0,0"
                                    Background="#EFE7D8"
                                    CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="#B3A79C"
                                               Text="&#xE72E;"/>
                                    <PasswordBox x:Name="PasswordBox"
                                                 Grid.Column="1"
                                                 Padding="0"
                                                 VerticalContentAlignment="Center"
                                                 Background="Transparent"
                                                 BorderBrush="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="#5E4A43"
                                                 PasswordChar="*"
                                                 KeyDown="LoginInput_KeyDown"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Grid Grid.Row="6">
                            <CheckBox x:Name="RememberMeCheckBox"
                                      VerticalAlignment="Center"
                                      IsChecked="True"
                                      Foreground="#8F7F75"
                                      Content="Remember Me"/>
                        </Grid>

                        <TextBlock x:Name="ErrorTextBlock"
                                   Grid.Row="8"
                                   Foreground="#805062"
                                   Visibility="Collapsed"/>

                        <Button Grid.Row="10"
                                Height="58"
                                Background="#946A5D"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="Bold"
                                Content="Enter"
                                Click="LoginButton_Click"/>
                    </Grid>
                </Border>

                <StackPanel VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,48">
                    <Grid Width="180">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Height="1"
                                VerticalAlignment="Center"
                                Background="#E7DCCB"/>
                        <Border Grid.Column="2"
                                Height="1"
                                VerticalAlignment="Center"
                                Background="#E7DCCB"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
