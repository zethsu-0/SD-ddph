<Window x:Class="ddph.Views.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Add Product"
        Height="640"
        Width="420"
        MinHeight="580"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource ThemeBaseBrush}"
        WindowStyle="None">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Close Button Overlay -->
        <Button Width="100"
                Height="36"
                Margin="0,-1,0,0"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Panel.ZIndex="100"
                FontSize="18"
                FontWeight="SemiBold"
                Background="{StaticResource ThemeAccentSoftBrush}"
                Foreground="{StaticResource ThemeInkBrush}"
                BorderBrush="{StaticResource ThemeAccentBrush}"
                BorderThickness="1"
                ToolTip="Back"
                Click="CloseButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                        <TextBlock Text="&#x2190;"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.82"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.65"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <StackPanel>
            <TextBlock x:Name="WindowTitleTextBlock"
                       Text="Add Product"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource ThemeInkBrush}"/>
            <TextBlock x:Name="WindowSubtitleTextBlock"
                       Text="Enter the product details below."
                       Margin="0,6,0,0"
                       Foreground="{StaticResource ThemeInkSoftBrush}"/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="18"
                Background="{StaticResource ThemeSurfaceBrush}"
                BorderBrush="{StaticResource ThemeBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Image Picker -->
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Product Image"
                                   Margin="0,0,0,6"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                        <Border x:Name="ImagePreviewBorder"
                                Height="130"
                                CornerRadius="10"
                                Background="{StaticResource ThemeAccentSoftBrush}"
                                BorderBrush="{StaticResource ThemeBorderBrush}"
                                BorderThickness="1"
                                ClipToBounds="True"
                                Margin="0,0,0,8">
                            <Grid>
                                <TextBlock x:Name="ImagePlaceholderText"
                                           Text="No image selected"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource ThemeOnSurfaceSoftBrush}"
                                           FontSize="13"/>
                                <Image x:Name="ImagePreview"
                                       Stretch="UniformToFill"
                                       Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ImageUrlTextBox"
                                     Height="34"
                                     VerticalContentAlignment="Center"
                                     Padding="8,0"
                                     FontSize="12"
                                     Foreground="{StaticResource ThemeInkSoftBrush}"
                                     TextChanged="ImageUrlTextBox_TextChanged"
                                     ToolTip="Paste an image URL or use Browse to pick a local file"/>
                            <Button Grid.Column="2"
                                    Content="Browse…"
                                    Width="80"
                                    Height="34"
                                    Background="{StaticResource ThemeAccentSoftBrush}"
                                    BorderBrush="{StaticResource ThemeBorderBrush}"
                                    FontWeight="SemiBold"
                                    Click="BrowseImageButton_Click"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="Product Name"
                                   Margin="0,0,0,6"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                        <TextBox x:Name="ProductNameTextBox"
                                 Height="34"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4">
                        <TextBlock Text="Price"
                                   Margin="0,0,0,6"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                        <TextBox x:Name="PriceTextBox"
                                 Height="34"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6">
                        <TextBlock Text="Category"
                                   Margin="0,0,0,6"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                        <ComboBox x:Name="CategoryComboBox"
                                  Height="34"
                                  VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="100"
                    Height="36"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button x:Name="SaveButton"
                    Content="Save"
                    Width="100"
                    Height="36"
                    Background="{StaticResource ThemeAccentBrush}"
                    Foreground="{StaticResource ThemeInkBrush}"
                    BorderBrush="{StaticResource ThemeAccentBrush}"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
