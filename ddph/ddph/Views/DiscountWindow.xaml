<Window x:Class="ddph.Views.DiscountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Apply Discount"
        Width="360"
        Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Border Margin="12"
            Padding="22"
            Background="#FFFDFC"
            BorderBrush="#26D4C3BE"
            BorderThickness="1"
            CornerRadius="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <StackPanel>
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="22"
                               FontFamily="{StaticResource ThemeHeadlineFont}"
                               FontWeight="Bold"
                               Foreground="{StaticResource ThemeInkBrush}"
                               Text="Apply Discount"/>
                    <TextBlock Margin="0,8,0,0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="{StaticResource ThemeInkSoftBrush}"
                               Text="Select customer type, then choose a discount rate."/>
                </StackPanel>
                <Button Width="30"
                        Height="30"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="#FFFFFF"
                        BorderBrush="#26D4C3BE"
                        BorderThickness="1"
                        Click="CloseButton_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Foreground="{StaticResource ThemeInkSoftBrush}"
                               Text="&#xE711;"/>
                </Button>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="PwdButton"
                        Grid.Column="0"
                        Height="110"
                        Background="#FFFFFF"
                        BorderBrush="#26D4C3BE"
                        BorderThickness="1.5"
                        Click="PwdButton_Click">
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{StaticResource ThemeInkBrush}"
                                   Text="&#xE13D;"/>
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ThemeInkBrush}"
                                   Text="PWD"/>
                        <Border Margin="16,8,16,0"
                                Padding="6,3"
                                Background="#E6F1FB"
                                CornerRadius="12">
                            <TextBlock HorizontalAlignment="Center"
                                       FontSize="10"
                                       Foreground="#185FA5"
                                       Text="Person w/ Disability"/>
                        </Border>
                    </StackPanel>
                </Button>
                <Button x:Name="SeniorButton"
                        Grid.Column="2"
                        Height="110"
                        Background="#FFFFFF"
                        BorderBrush="#26D4C3BE"
                        BorderThickness="1.5"
                        Click="SeniorButton_Click">
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{StaticResource ThemeInkBrush}"
                                   Text="&#xE77B;"/>
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ThemeInkBrush}"
                                   Text="Senior Citizen"/>
                        <Border Margin="16,8,16,0"
                                Padding="6,3"
                                Background="#FAEEDA"
                                CornerRadius="12">
                            <TextBlock HorizontalAlignment="Center"
                                       FontSize="10"
                                       Foreground="#854F0B"
                                       Text="60 years &amp; above"/>
                        </Border>
                    </StackPanel>
                </Button>
            </Grid>

            <StackPanel Grid.Row="4">
                <TextBlock FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ThemeInkSoftBrush}"
                           Text="DISCOUNT RATE"/>
                <UniformGrid Margin="0,10,0,0"
                             Rows="2"
                             Columns="3">
                    <Button x:Name="Discount5Button" Margin="0,0,8,8" Tag="5" Click="PresetDiscount_Click" Content="5%"/>
                    <Button x:Name="Discount10Button" Margin="0,0,8,8" Tag="10" Click="PresetDiscount_Click" Content="10%"/>
                    <Button x:Name="Discount15Button" Margin="0,0,0,8" Tag="15" Click="PresetDiscount_Click" Content="15%"/>
                    <Button x:Name="Discount20Button" Margin="0,0,8,0" Tag="20" Click="PresetDiscount_Click" Content="20%"/>
                    <Button x:Name="Discount25Button" Margin="0,0,8,0" Tag="25" Click="PresetDiscount_Click" Content="25%"/>
                    <Button x:Name="Discount50Button" Tag="50" Click="PresetDiscount_Click" Content="50%"/>
                </UniformGrid>
            </StackPanel>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="CustomDiscountTextBox"
                         Height="42"
                         VerticalContentAlignment="Center"
                         ToolTip="Custom %"
                         TextChanged="CustomDiscountTextBox_TextChanged"/>
                <TextBlock Grid.Column="1"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource ThemeInkSoftBrush}"
                           Text="%"/>
            </Grid>

            <StackPanel Grid.Row="8">
                <Border Padding="12"
                        Background="#F5EDDE"
                        CornerRadius="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{StaticResource ThemeInkSoftBrush}"
                                   Text="Discount applied"/>
                        <TextBlock x:Name="PreviewTextBlock"
                                   Grid.Column="1"
                                   FontWeight="SemiBold"
                                   Foreground="#FF52352C"
                                   Text="select above"/>
                    </Grid>
                </Border>
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Height="46"
                            Background="#FFFFFF"
                            Click="ClearButton_Click"
                            Content="Clear"/>
                    <Button Grid.Column="2"
                            Height="46"
                            Background="#765449"
                            Foreground="White"
                            Click="ApplyButton_Click"
                            Content="Apply Discount"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
