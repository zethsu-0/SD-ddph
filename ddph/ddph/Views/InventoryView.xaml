<UserControl x:Class="ddph.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ddph.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1280"
             Background="#FFF8EF">
    <UserControl.Resources>
        <converters:ProductImageConverter x:Key="ProductImageConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <SolidColorBrush x:Key="InvShellBrush" Color="#FFF8EF"/>
        <SolidColorBrush x:Key="InvPanelBrush" Color="#F5EDDE"/>
        <SolidColorBrush x:Key="InvPanelSoftBrush" Color="#FBF3E4"/>
        <SolidColorBrush x:Key="InvCardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InvBorderBrush" Color="#26D4C3BE"/>
        <SolidColorBrush x:Key="InvPrimaryBrush" Color="#765449"/>
        <SolidColorBrush x:Key="InvTextBrush" Color="#1E1B13"/>
        <SolidColorBrush x:Key="InvTextSoftBrush" Color="#504441"/>
        <SolidColorBrush x:Key="InvOutlineBrush" Color="#827470"/>
        <SolidColorBrush x:Key="InvGreenBrush" Color="#266931"/>
        <SolidColorBrush x:Key="InvGreenSoftBrush" Color="#F2F6F1"/>
        <SolidColorBrush x:Key="InvRoseBrush" Color="#805062"/>
        <SolidColorBrush x:Key="InvRoseSoftBrush" Color="#FDF3F5"/>
        <LinearGradientBrush x:Key="InvBreadBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#765449" Offset="0"/>
            <GradientStop Color="#916C60" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="InventoryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource InvCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InvBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
        </Style>
        <Style x:Key="InventoryIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="{StaticResource InvPanelSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InvBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource InvShellBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="InventoryScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource InvShellBrush}">
            <Grid Margin="32"
                  MinWidth="940">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               FontWeight="Medium"
                               Foreground="{StaticResource InvTextSoftBrush}"
                               Text="Manage inventory items and daily supply."/>
                    <Button Grid.Column="1"
                            Height="52"
                            Padding="24,0"
                            Command="{Binding AddProductCommand}"
                            Background="{StaticResource InvBreadBrush}"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="White"
                                       Text="&#xE710;"/>
                            <TextBlock VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Text="Add New Item"/>
                        </StackPanel>
                    </Button>

                    <Grid Grid.Row="2"
                          Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <Border Height="52"
                                Padding="18,0"
                                Background="{StaticResource InvCardBrush}"
                                BorderBrush="{StaticResource InvBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="{StaticResource InvPrimaryBrush}"
                                           Text="&#xE721;"/>
                                <TextBox Grid.Column="1"
                                         Margin="12,0,0,0"
                                         VerticalContentAlignment="Center"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="14"
                                         Foreground="{StaticResource InvTextBrush}"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </Border>

                        <ComboBox Grid.Column="2"
                                  Height="52"
                                  Padding="14,0"
                                  Background="{StaticResource InvCardBrush}"
                                  BorderBrush="{StaticResource InvPanelBrush}"
                                  BorderThickness="1"
                                  Foreground="{StaticResource InvTextBrush}"
                                  ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"
                                          MinWidth="260"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"
                                          MinWidth="620"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Border Padding="28"
                                Background="{StaticResource InvPanelBrush}"
                                BorderBrush="{StaticResource InvBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="24">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="28"
                                           Foreground="{StaticResource InvRoseBrush}"
                                           Text="&#xE7BA;"/>
                                <TextBlock Margin="0,16,0,0"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource InvTextBrush}"
                                           Text="{Binding VisibleProductCount}"/>
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource InvTextSoftBrush}"
                                           Text="Visible inventory items"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,24,0,0"
                                Background="{StaticResource InvGreenSoftBrush}"
                                BorderBrush="{StaticResource InvBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="24">
                            <StackPanel>
                                <TextBlock Margin="20,18,20,0"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource InvTextSoftBrush}"
                                           Text="Latest Product"/>
                                <ContentControl Content="{Binding LatestProduct}">
                                    <ContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="180"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Border Margin="0,16,0,0"
                                                        ClipToBounds="True"
                                                        Background="{StaticResource InvPanelBrush}">
                                                    <Image Source="{Binding ImageUrl, Converter={StaticResource ProductImageConverter}}"
                                                           Stretch="UniformToFill"/>
                                                </Border>
                                                <TextBlock Grid.Row="1"
                                                           Margin="20,16,20,20"
                                                           FontSize="22"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource InvGreenBrush}"
                                                           Text="{Binding ProductName}"
                                                           TextWrapping="Wrap"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ContentControl.ContentTemplate>
                                </ContentControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Style="{StaticResource InventoryCardStyle}">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Background="{StaticResource InvPanelSoftBrush}"
                                    BorderBrush="{StaticResource InvBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    CornerRadius="20,20,0,0">
                                <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"
                                                      MinWidth="260"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="104"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Margin="24,18"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource InvOutlineBrush}"
                                           Cursor="Hand"
                                           Text="Product Name">
                                    <TextBlock.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding SortProductsCommand}"
                                                      CommandParameter="ProductName"/>
                                    </TextBlock.InputBindings>
                                </TextBlock>
                                <TextBlock Grid.Column="1"
                                           Margin="20,18"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource InvOutlineBrush}"
                                           Cursor="Hand"
                                           Text="Category">
                                    <TextBlock.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding SortProductsCommand}"
                                                      CommandParameter="Category"/>
                                    </TextBlock.InputBindings>
                                </TextBlock>
                                <TextBlock Grid.Column="2"
                                           Margin="20,18"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource InvOutlineBrush}"
                                           Cursor="Hand"
                                           Text="Unit Price">
                                    <TextBlock.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding SortProductsCommand}"
                                                      CommandParameter="Price"/>
                                    </TextBlock.InputBindings>
                                </TextBlock>
                                <TextBlock Grid.Column="3"
                                           Margin="20,18"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource InvOutlineBrush}"
                                           Text="Action"/>
                                </Grid>
                            </Border>

                            <ListBox Grid.Row="1"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ItemsSource="{Binding FilteredProducts}"
                                     PreviewMouseWheel="ProductListBox_PreviewMouseWheel"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#33D4C3BE"
                                                BorderThickness="0,0,0,1"
                                                Background="Transparent">
                                            <Grid MinHeight="92">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3*"
                                                                      MinWidth="260"/>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="104"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid Margin="24,18">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="56"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="56"
                                                            Height="56"
                                                            CornerRadius="12"
                                                            ClipToBounds="True"
                                                            Background="{StaticResource InvPanelBrush}">
                                                        <Image Source="{Binding ImageUrl, Converter={StaticResource ProductImageConverter}}"
                                                               Stretch="UniformToFill"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="2"
                                                                VerticalAlignment="Center">
                                                        <TextBlock FontSize="16"
                                                                   FontWeight="Bold"
                                                                   Foreground="{StaticResource InvTextBrush}"
                                                                   Text="{Binding ProductName}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Margin="0,4,0,0"
                                                                   FontSize="14"
                                                                   Foreground="{StaticResource InvTextSoftBrush}"
                                                                   Text="{Binding Description}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Border Grid.Column="1"
                                                        Margin="20,28"
                                                        Padding="12,6"
                                                        HorizontalAlignment="Left"
                                                        Background="{StaticResource InvPanelBrush}"
                                                        CornerRadius="14">
                                                    <TextBlock FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource InvPrimaryBrush}"
                                                               Text="{Binding Category}"/>
                                                </Border>

                                                <TextBlock Grid.Column="2"
                                                           Margin="20,28"
                                                           VerticalAlignment="Center"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource InvTextBrush}"
                                                           Text="{Binding Price, StringFormat={}{0:C}}"/>

                                                <StackPanel Grid.Column="3"
                                                            Margin="12,20"
                                                            HorizontalAlignment="Center"
                                                            Orientation="Horizontal">
                                                    <Button Margin="0,0,8,0"
                                                            Style="{StaticResource InventoryIconButtonStyle}"
                                                            Command="{Binding DataContext.EditProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="18"
                                                                   Foreground="{StaticResource InvPrimaryBrush}"
                                                                   Text="&#xE70F;"/>
                                                    </Button>
                                                    <Button Style="{StaticResource InventoryIconButtonStyle}"
                                                            Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="18"
                                                                   Foreground="{StaticResource InvRoseBrush}"
                                                                   Text="&#xE74D;"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Grid.Row="2"
                                    Padding="24,18"
                                    Background="{StaticResource InvPanelSoftBrush}"
                                    BorderBrush="{StaticResource InvBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    CornerRadius="0,0,20,20">
                                <TextBlock Foreground="{StaticResource InvOutlineBrush}"
                                           Text="{Binding VisibleProductCount, StringFormat=Showing {0} products}"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Border Panel.ZIndex="50"
                Background="#CCFFF8EF"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="414,300,0,0">
            <ProgressBar Width="180"
                         Height="8"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         IsIndeterminate="True"/>
        </Border>
    </Grid>
</UserControl>
