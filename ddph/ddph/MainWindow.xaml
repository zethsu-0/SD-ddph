<Window x:Class="ddph.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ddph"
        mc:Ignorable="d"
        Title="POS System"
        Height="720"
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        Background="#F5F5F5" WindowState="Maximized">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#EAEAEA"
                        CornerRadius="6"
                        Height="40"
                        VerticalAlignment="Center">
                    <TextBlock Text="LOGO"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               FontSize="16"/>
                </Border>

                <TextBlock Grid.Column="2"
                           Text="Search Product"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,8,0"/>

                <TextBox Grid.Column="3"
                         Height="36"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         Padding="10,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Column="5"
                           Text="Date"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,8,0"/>

                <DatePicker Grid.Column="6"
                            Height="36"
                            SelectedDate="{x:Static sys:DateTime.Now}"
                            xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                <StackPanel Grid.Column="7"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Products"
                            Height="36"
                            Width="100"
                            Margin="0,2,8,2"
                            Click="Button_Click"/>
                    <Button Content="Online Orders"
                            Height="36"
                            Width="120"
                            Margin="0,2,8,2"
                            Click="OrdersButton_Click"/>
                    <Button Content="Custom Order"
                            Height="36"
                            Width="120"
                            Margin="0,2,0,2"
                            Click="CustomItemsButton_Click"/>
                </StackPanel>
                <TextBlock Grid.Column="8"
                           Text="User: Staff"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="14"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="0.8*"/>
            </Grid.ColumnDefinitions>

            <!-- Product Grid -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Product Grid"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <Grid Grid.Row="1"
                          Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding ProductCount, StringFormat=Available Products: {0}}"
                                   Foreground="#6B7280"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="Refresh"
                                Width="90"
                                Height="32"
                                Margin="12,0,0,0"
                                Command="{Binding RefreshProductsCommand}"/>
                    </Grid>

                    <ScrollViewer Grid.Row="3"
                                  Margin="0,4,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredProducts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="170"
                                            Height="120"
                                            Margin="6"
                                            Padding="0"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Command="{Binding DataContext.ProductButtonCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Border CornerRadius="14"
                                                BorderBrush="#D0D0D0"
                                                BorderThickness="1"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Border Background="#E5E7EB"/>
                                                <Image Source="{Binding ImageUrl}"
                                                       Stretch="UniformToFill"/>
                                                <Border Background="#66000000"/>

                                                <Grid Margin="12">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Text="{Binding Category}"
                                                               HorizontalAlignment="Left"
                                                               VerticalAlignment="Top"
                                                               Padding="8,4"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="White">
                                                        <TextBlock.Background>
                                                            <SolidColorBrush Color="#7F111827"/>
                                                        </TextBlock.Background>
                                                    </TextBlock>

                                                    <StackPanel Grid.Row="1">
                                                        <TextBlock Text="{Binding ProductName}"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding Price, StringFormat={}{0:C}}"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FDE68A"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Cart / Order Summary -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Cart / Order Summary"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding CartItems}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="*"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Qty}" Width="80"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0:C}}" Width="100"/>
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="-"
                                                Width="28"
                                                Height="28"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.RemoveCartItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                    </DataGrid>

                    <TextBlock Grid.Row="4"
                               Text="{Binding CartTotal, StringFormat=Total: {0:C}}"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"/>

                    <StackPanel Grid.Row="6">
                        <TextBlock Text="Payment"
                                   Margin="0,0,0,6"
                                   FontWeight="SemiBold"/>
                        <TextBox x:Name="PaymentTextBox"
                                 Height="36"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 Text="{Binding PaymentText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="8"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Checkout"
                                Width="110"
                                Height="40"
                                Margin="0,0,8,0"
                                Command="{Binding CheckoutCommand}"/>
                        <Button Content="Clear"
                                Width="90"
                                Height="40"
                                Command="{Binding ClearCartCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Filters -->
        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Filters"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="16"/>

                <ComboBox Grid.Column="2"
                          Height="36"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory, UpdateSourceTrigger=PropertyChanged}"/>

                <CheckBox Grid.Column="4"
                          Content="In Stock Only"
                          VerticalAlignment="Center"
                          IsChecked="{Binding ShowInStockOnly, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Column="6"
                           Text="{Binding ProductCount, StringFormat=Showing: {0}}"
                           VerticalAlignment="Center"
                           Foreground="#6B7280"
                           FontWeight="SemiBold"/>

                <Button Grid.Column="8"
                        Content="Clear Filters"
                        Width="110"
                        Height="36"
                        Command="{Binding ClearFiltersCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Window>

