<Window x:Class="ddph.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ddph"
        mc:Ignorable="d"
        Title="POS System"
        Height="720"
        Width="1378"
        MinHeight="600"
        MinWidth="900"
        Background="{StaticResource ThemeBaseBrush}"
        WindowState="Maximized"
        WindowStyle="None">
    <Window.Resources>
        <Style x:Key="SurfaceCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ThemeSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
        </Style>

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="{StaticResource ThemeAccentSoftBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ThemeInkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ThemeAccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ThemeInkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ThemeAccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ThemeAccentSoftBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ThemeInkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0,1,0,18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="53*"/>
            <ColumnDefinition Width="463*"/>
            <ColumnDefinition Width="155*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Close Button Overlay -->
        <Button Content="✕"
                Width="36"
                Height="36"
                Margin="0,-1,0,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="100"
                FontSize="14"
                FontWeight="Bold"
                Background="{StaticResource ThemeSurfaceBrush}"
                Foreground="{StaticResource ThemeOnSurfaceBrush}"
                BorderBrush="{StaticResource ThemeSurfaceBrush}"
                ToolTip="Close"
                Grid.Column="2"
                Click="CloseButton_Click"/>

        <!-- Top Bar -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Margin="0,0,0,0"
                Padding="18,14"
                Background="{StaticResource ThemeBaseBrush}"
                BorderThickness="0"
                BorderBrush="Transparent">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">
                    <TextBlock Text="DreamDough POS"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ThemeInkBrush}"/>
                    <TextBlock Margin="0,4,0,0"
                               Text="Warm bakery checkout for walk-in customers"
                               Foreground="{StaticResource ThemeInkSoftBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="0,-14,48,0"
                            HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Products"
                                Width="100"
                                Style="{StaticResource HeaderActionButtonStyle}"
                                Click="Button_Click"/>
                        <Button Content="Online Orders"
                                Width="120"
                                Style="{StaticResource HeaderActionButtonStyle}"
                                Click="OrdersButton_Click"/>
                        <Button Content="Custom Order"
                                Width="120"
                                Margin="0"
                                Style="{StaticResource HeaderActionButtonStyle}"
                                Click="CustomItemsButton_Click"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Margin="0,47,-4,-9"
                               Text="User: Staff"
                               HorizontalAlignment="Right"
                               FontWeight="Bold"
                               FontSize="14"
                               Foreground="{StaticResource ThemeInkBrush}" Grid.Column="1"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>

            <!-- Product Grid -->
            <Border Grid.Column="0"
                    Style="{StaticResource SurfaceCardStyle}"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Product Gallery"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                            <TextBox Margin="0,10,0,0"
                                     Width="260"
                                     Height="36"
                                     Padding="12,0"
                                     VerticalContentAlignment="Center"
                                     Background="{StaticResource ThemeAccentSoftBrush}"
                                     BorderBrush="{StaticResource ThemeBorderBrush}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Padding="14,10"
                                Background="{StaticResource ThemeAccentSoftBrush}"
                                BorderBrush="{StaticResource ThemeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="{Binding ProductCount, StringFormat={}{0}}"
                                           HorizontalAlignment="Center"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ThemeInkBrush}"/>
                                <TextBlock Text="Visible Today"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource ThemeInkSoftBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Content="Refresh Products"
                                Width="132"
                                Height="36"
                                Margin="12,0,0,0"
                                Command="{Binding RefreshProductsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </Grid>

                    <ScrollViewer Grid.Row="3"
                                  Margin="0,4,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredProducts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="190"
                                            Height="148"
                                            Margin="0,0,14,14"
                                            Padding="0"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Command="{Binding DataContext.ProductButtonCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Border CornerRadius="18"
                                                BorderBrush="{StaticResource ThemeBorderBrush}"
                                                BorderThickness="1"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Border Background="{StaticResource ThemeAccentSoftBrush}"/>
                                                <Image Source="{Binding ImageUrl}"
                                                       Stretch="UniformToFill"/>
                                                <Rectangle>
                                                    <Rectangle.Fill>
                                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                            <GradientStop Color="#00000000" Offset="0"/>
                                                            <GradientStop Color="#33000000" Offset="0.45"/>
                                                            <GradientStop Color="#B52C2C2E" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Rectangle.Fill>
                                                </Rectangle>

                                                <Grid Margin="14">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Text="{Binding Category}"
                                                               HorizontalAlignment="Left"
                                                               VerticalAlignment="Top"
                                                               Padding="10,5"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="White">
                                                        <TextBlock.Background>
                                                            <SolidColorBrush Color="#CC2C2C2E"/>
                                                        </TextBlock.Background>
                                                    </TextBlock>

                                                    <StackPanel Grid.Row="1">
                                                        <TextBlock Text="{Binding ProductName}"
                                                                   FontSize="17"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding Price, StringFormat={}{0:C}}"
                                                                   FontSize="15"
                                                                   FontWeight="Bold"
                                                                   Foreground="{StaticResource ThemeAccentBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Cart / Order Summary -->
            <Border Grid.Column="2"
                    Style="{StaticResource SurfaceCardStyle}"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Current Order"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                        <TextBlock Margin="0,4,0,0"
                                   Text="Review quantities, payment, and finalize the sale."
                                   Foreground="{StaticResource ThemeOnSurfaceSoftBrush}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding CartItems}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              BorderThickness="0"
                              Background="Transparent"
                              RowHeaderWidth="0"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource ThemeAccentSoftBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource ThemeInkBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Height" Value="46"/>
                                <Setter Property="BorderBrush" Value="{StaticResource ThemeBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="*"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Qty}" Width="70"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0:C}}" Width="90"/>
                            <DataGridTemplateColumn Header="" Width="54">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="-"
                                                Width="28"
                                                Height="28"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.RemoveCartItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                    </DataGrid>

                    <Border Grid.Row="4"
                            Padding="14"
                            Background="{StaticResource ThemeAccentSoftBrush}"
                            BorderBrush="{StaticResource ThemeBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Order Total"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource ThemeInkSoftBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CartTotal, StringFormat={}{0:C}}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ThemeInkBrush}"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="6">
                        <TextBlock Text="Payment"
                                   Margin="0,0,0,6"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ThemeOnSurfaceBrush}"/>
                        <TextBox x:Name="PaymentTextBox"
                                 Height="40"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"
                                 Text="{Binding PaymentText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="8"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Checkout"
                                Width="120"
                                Height="42"
                                Margin="0,0,8,0"
                                Command="{Binding CheckoutCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Content="Clear"
                                Width="100"
                                Height="42"
                                Command="{Binding ClearCartCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Filters -->
        <Border Grid.Row="4"
                Style="{StaticResource SurfaceCardStyle}"
                Padding="16" Grid.ColumnSpan="3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Filters"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="18"
                           Foreground="{StaticResource ThemeOnSurfaceBrush}"/>

                <ComboBox Grid.Column="2"
                          Height="36"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory, UpdateSourceTrigger=PropertyChanged}"
                          Background="{StaticResource ThemeAccentSoftBrush}"
                          BorderBrush="{StaticResource ThemeBorderBrush}"/>

                <TextBlock Grid.Column="4"
                           Text="{Binding ProductCount, StringFormat=Showing {0} items}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource ThemeOnSurfaceSoftBrush}"
                           FontWeight="SemiBold"/>

                <Button Grid.Column="6"
                        Content="Clear Filters"
                        Width="118"
                        Height="36"
                        Command="{Binding ClearFiltersCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Window>

