<Window x:Class="ddphkiosk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:controls="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ddphkiosk"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Dream Dough PH"
        Width="1600"
        Height="900"
        MinWidth="1280"
        MinHeight="760"
        Loaded="Window_Loaded"
        Background="#FBF9F5"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        mc:Ignorable="d">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="40"
                          ShadowDepth="0"
                          Opacity="0.10"
                          Color="#31332F" />

        <SolidColorBrush x:Key="SurfaceBrush" Color="#FBF9F5" />
        <SolidColorBrush x:Key="SurfaceLowBrush" Color="#F5F3EF" />
        <SolidColorBrush x:Key="SurfaceLowestBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurfaceHighBrush" Color="#E9E8E3" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#576342" />
        <SolidColorBrush x:Key="SecondaryBrush" Color="#8D4E36" />
        <SolidColorBrush x:Key="TextBrush" Color="#31332F" />
        <SolidColorBrush x:Key="MutedBrush" Color="#5E605B" />

        <Style x:Key="SerifText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Noto Serif" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="SansText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Plus Jakarta Sans" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="TopNavButton" TargetType="Button">
            <Setter Property="Background" Value="#F3EEE6" />
            <Setter Property="BorderBrush" Value="#10FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="22,12" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Noto Serif" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Effect="{StaticResource CardShadow}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="True">
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="#FFF8F1" />
                                <Setter TargetName="TabBorder"
                                        Property="BorderBrush"
                                        Value="#40FFFFFF" />
                                <Setter Property="Foreground"
                                        Value="{StaticResource SecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="#F8F3EC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ItemsPanelTemplate x:Key="TabPanelTemplate">
            <StackPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="#FFF7F5" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="22,12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Plus Jakarta Sans" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="16"
                                Background="{StaticResource SecondaryBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceHighBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Plus Jakarta Sans" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="14"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceLowBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="FontFamily" Value="Plus Jakarta Sans" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="InputComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceLowBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontFamily" Value="Plus Jakarta Sans" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="InputDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Background" Value="{StaticResource SurfaceLowBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="FontFamily" Value="Plus Jakarta Sans" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <DataTemplate x:Key="ProductCardTemplate"
                      DataType="{x:Type local:ProductCard}">
            <Border Width="320"
                    Height="320"
                    Margin="0,0,24,24"
                    CornerRadius="18"
                    ClipToBounds="True"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Border Background="{Binding ArtBrush}" />
                    <Image Source="{Binding ProductImageSource}"
                           Stretch="UniformToFill" />
                    <Rectangle Fill="#3A000000" />
                    <Rectangle VerticalAlignment="Bottom"
                               Height="150">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="0,1">
                                <GradientStop Color="#00FFFFFF" Offset="0" />
                                <GradientStop Color="#D231332F" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Border Margin="18"
                            Padding="8,4"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#B3576342"
                            CornerRadius="12">
                        <TextBlock Style="{StaticResource SansText}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#F0FFD3"
                                   Text="{Binding Eyebrow}" />
                    </Border>
                    <StackPanel Margin="20"
                                VerticalAlignment="Bottom">
                        <TextBlock Style="{StaticResource SerifText}"
                                   FontSize="26"
                                   Foreground="#FBF9F5"
                                   Text="{Binding Name}"
                                   TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource SansText}"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   Foreground="#F7F4EF"
                                   Text="{Binding Description}"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxHeight="34" />
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SerifText}"
                                       VerticalAlignment="Center"
                                       FontSize="24"
                                       Foreground="#FFF3EC"
                                       Text="{Binding PriceDisplay}" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource PrimaryActionButton}"
                                    FontSize="28"
                                    FontWeight="Bold"
                                    Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Content="  +  " />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource SurfaceBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.ColumnSpan="2"
                Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="48,22,48,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SerifText}"
                               FontSize="30"
                               FontStyle="Italic"
                               Foreground="{StaticResource SecondaryBrush}"
                               Text="Dream Dough PH" />
                    <Border Margin="32,0,0,0"
                            Padding="14"
                            Background="#EDE5D9"
                            CornerRadius="28">
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:CategoryTab}">
                                    <Button Style="{StaticResource TopNavButton}"
                                            Width="150"
                                            Height="46"
                                            Tag="{Binding IsSelected}"
                                            Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding Name}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="48,12,48,40">

                <ItemsControl Margin="0,24,0,0"
                              ItemTemplate="{StaticResource ProductCardTemplate}"
                              ItemsSource="{Binding FilteredProducts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <Border Margin="0,34,0,0"
                        Padding="24,26,24,18"
                        BorderBrush="#0631332F"
                        BorderThickness="0,1,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource SansText}"
                                       Margin="0,0,48,0"
                                       FontSize="12"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Opacity="0.6"
                                       Text="SOURCING" />
                            <TextBlock Style="{StaticResource SansText}"
                                       Margin="0,0,48,0"
                                       FontSize="12"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Opacity="0.6"
                                       Text="ALLERGENS" />
                            <TextBlock Style="{StaticResource SansText}"
                                       FontSize="12"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Opacity="0.6"
                                       Text="CONTACT" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource SansText}"
                                   Margin="0,16,0,0"
                                   FontSize="10"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Text="{Binding StatusMessage}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Grid.Column="1"
                Background="#F2EFE9"
                BorderBrush="#0631332F"
                BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="32,32,32,16">
                    <TextBlock Style="{StaticResource SerifText}"
                               FontSize="28"
                               Foreground="{StaticResource PrimaryBrush}"
                               Text="Your Tray" />
                    <TextBlock Style="{StaticResource SansText}"
                               Margin="0,8,0,0"
                               FontSize="14"
                               Opacity="0.6"
                               Text="Freshly picked" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="32,18,32,18">
                        <ItemsControl ItemsSource="{Binding CartItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:CartItem}">
                                    <Grid Margin="0,0,0,24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="64"
                                                Height="64"
                                                CornerRadius="12"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Border Background="{Binding Product.ArtBrush}" />
                                                <Image Source="{Binding Product.ProductImageSource}"
                                                       Width="120"
                                                       Height="120"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       Stretch="UniformToFill" />
                                            </Grid>
                                        </Border>
                                        <Grid Grid.Column="1"
                                              Margin="16,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SansText}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Product.ShortName}" />
                                                <TextBlock Style="{StaticResource SansText}"
                                                           Margin="0,6,0,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Text="{Binding QuantityDisplay}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Style="{StaticResource SansText}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding TotalDisplay}" />
                                        </Grid>
                                        <Button Grid.Column="2"
                                                Width="36"
                                                Height="36"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource SecondaryActionButton}"
                                                Background="#C64242"
                                                Foreground="#FFF7F5"
                                                Command="{Binding DataContext.DecreaseCartItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Content="-" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Style="{StaticResource SansText}"
                                   Margin="0,8,0,8"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="FULL NAME" />
                        <TextBox Style="{StaticResource InputBoxStyle}"
                                 MaxLength="50"
                                 PreviewTextInput="NameTextBox_PreviewTextInput"
                                 DataObject.Pasting="NameTextBox_Pasting"
                                 Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource SansText}"
                                   Margin="0,14,0,8"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="PHONE" />
                        <TextBox Style="{StaticResource InputBoxStyle}"
                                 MaxLength="11"
                                 InputScope="TelephoneNumber"
                                 PreviewTextInput="PhoneTextBox_PreviewTextInput"
                                 DataObject.Pasting="PhoneTextBox_Pasting"
                                 Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource SansText}"
                                   Margin="0,14,0,8"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="PICKUP DATE" />
                        <DatePicker x:Name="PickupDatePicker"
                                    Style="{StaticResource InputDatePickerStyle}"
                                    DisplayDateStart="{Binding TodayDate, Mode=OneWay}"
                                    SelectedDate="{Binding PickupDate, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource SansText}"
                                   Margin="0,14,0,8"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="PICKUP TIME" />
                        <ComboBox Style="{StaticResource InputComboStyle}"
                                  ItemsSource="{Binding PickupTimeOptions}"
                                  SelectedItem="{Binding PickupTime, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Style="{StaticResource SansText}"
                                   Margin="0,14,0,8"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="NOTES" />
                        <TextBox Style="{StaticResource InputBoxStyle}"
                                 Height="82"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Padding="32"
                        Background="#EFECDF"
                        BorderBrush="#0631332F"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SansText}"
                                       FontSize="15"
                                       Foreground="{StaticResource MutedBrush}"
                                       Text="Subtotal" />
                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource SansText}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="{Binding CartSubtotalDisplay}" />
                        </Grid>
                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <Button Height="56"
                                    Style="{StaticResource SecondaryActionButton}"
                                    Background="#D8D1C4"
                                    Command="{Binding ClearCartCommand}"
                                    Content="Clear" />
                            <Button Grid.Column="2"
                                    Height="56"
                                    Style="{StaticResource PrimaryActionButton}"
                                    Command="{Binding SubmitOrderCommand}"
                                    Content="Complete Order" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
